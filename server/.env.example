# Copy to server/.env and fill in. server/.env is gitignored — never commit it.

# HTTP port the API listens on
PORT=8000

# MongoDB connection string (local or MongoDB Atlas)
#   local:  mongodb://127.0.0.1:27017/matrix
#   atlas:  mongodb+srv://<user>:<pass>@<cluster>/matrix?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/matrix

# REQUIRED — secret used to sign JWTs. Use a long random string
# (e.g. `openssl rand -hex 32`). The server now REFUSES TO BOOT without it.
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES=7d

# Comma-separated list of allowed frontend origins (for credentialed CORS).
# On deploy this MUST be the exact deployed frontend origin(s), e.g.
#   CLIENT_ORIGIN=https://app.example.com,https://www.example.com
# A trailing slash or wrong scheme/port will break login.
CLIENT_ORIGIN=https://data-ranker.vercel.app

# Set to "production" on deploy so auth cookies become Secure + SameSite=None.
# NOTE: because the frontend and backend run on separate domains, the auth
# cookie is a THIRD-PARTY cookie. Safari and strict Chrome settings may block
# it — acceptable for a Chrome-based prototype demo, but plan a same-site
# setup (shared domain / reverse proxy) for real production.
NODE_ENV=development

# Google OAuth — required only if you want "Sign in with Google".
# Create a project at https://console.cloud.google.com, enable Google Identity,
# create an OAuth 2.0 Web Client ID, and add your frontend origin to
# "Authorized JavaScript origins". Paste the Client ID here and in client/.env.
GOOGLE_CLIENT_ID=

# Gmail credentials for sending emails (OTP, rankings summary, results).
# GMAIL_USER — the primary Google Workspace account (abhi@thinkvest.in).
#   noreply@thinkvest.in is an alias of this account so Google allows sending from it.
# GMAIL_APP_PASSWORD — App Password for GMAIL_USER (not the regular password).
#   Generate one at: Google Workspace account → Security → 2-Step Verification → App passwords.
# Emails display as "ThinkVest <noreply@thinkvest.in>" to recipients.
# Leave both blank to disable email sending (OTP routes will return 500).
GMAIL_USER=abhi@thinkvest.in
GMAIL_APP_PASSWORD=
