# Copy to client/.env. client/.env is gitignored — never commit it.

# Base URL of the Matrix backend API
REACT_APP_API_URL=http://localhost:8000

# Public site origin — used for canonical/Open Graph URLs in SEO metadata.
# Set this to the real deployed domain (no trailing slash). Also replace
# "matrix.example.com" in public/robots.txt and public/sitemap.xml.
REACT_APP_SITE_URL=https://matrix.example.com
